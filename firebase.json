{
  "projects": {
    "default": "restaurant-app"
  },
  "firestore": {
    "rules": "packages/backend/firestore.rules",
    "indexes": "packages/backend/firestore.indexes.json"
  },
  "functions": {
    "source": "packages/backend",
    "codebase": "ts",
    "runtime": "nodejs20"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "functions": {
      "port": 5001
    },
    "pubsub": {
      "port": 8085
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
